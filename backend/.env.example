SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

USE_SQLITE=False
DB_NAME=asset_management_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Production: Supabase (or any Postgres) connection string, overrides DB_* above
DATABASE_URL=postgresql://user:password@host:5432/postgres

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.onrender.com
SECURE_SSL_REDIRECT=True

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# SOC dashboard integration: where to POST audit events, and shared secret for HMAC signing
SOC_WEBHOOK_URL=https://soc-dashboard.example.com/api/webhooks/asset-management/
SOC_WEBHOOK_SECRET=change-this-to-a-shared-secret
